RAW_DATA_PATH=data/raw/housing.csv
TARGET_COLUMN=SalePrice
MODEL_PATH=models/house_price_model.joblib
TEST_SIZE=0.2
RANDOM_STATE=42
APP_NAME=House Price Prediction API
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=sqlite:///data/processed/house_price_prediction.db
MODEL_NAME=house-price-random-forest
MODEL_VERSION=0.1.0
ENABLE_MOCK_PREDICTOR=true
PROPERTY_DATA_PROVIDER=free-fallback
GEOCODING_PROVIDER=free-fallback
PREDICTION_REUSE_MAX_AGE_HOURS=24
PROVIDER_TIMEOUT_SECONDS=3.0
PROVIDER_MAX_RETRIES=2
